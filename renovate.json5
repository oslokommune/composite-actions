{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>oslokommune/golden-path-renovate:default.json5"
  ],
  "prConcurrentLimit": 100,
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "semanticCommitType": "deps",
      "semanticCommitScope": null
    },
    {
      "matchFileNames": ["setup-ok/action.yml"],
      "matchManagers": ["custom.regex"],
      "groupName": "setup-ok tool versions",
      "separateMajorMinor": false
    }
  ],
  "customManagers": [
    {
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?( extractVersion=(?<extractVersion>.*?))?\\s*default: [\"'](?<currentValue>.*?)[\"']"
      ],
      "fileMatch": ["^setup-ok/action\\.yml$"],
      "customType": "regex",
    },
    {
      "matchStrings": [
        "#\\s*renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( extractVersion=(?<extractVersion>.*?))?\\n.*_VERSION=\"(?<currentValue>.*)\""
      ],
      "fileMatch": ["^build-gp-config/action\\.yml$"],
      "customType": "regex",
    }
  ]
}
